params {
  project_folder = "$PWD"
  deeptools_output = "deeptools_heatmap_output"

  bigwig_pattern = "/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines/nf-bamcoverage/bamcoverage_output/bigwig/*.bw"

  // Choose one regions input mode:
  regions_bed = null
  regions_pattern = "/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines/nf-idr/idr_output/*_idr.sorted.chr.bed"
  regions_sheet = null   // CSV with columns: set_name,bed

  matrix_mode = "reference-point" // reference-point | scale-regions
  reference_point = "center"      // TSS | TES | center
  before_region_start_length = 3000
  after_region_start_length  = 3000
  region_body_length = 5000
  bin_size = 50

  color_map = "RdYlBu_r"
  dpi = 300
  heatmap_height = 10
  heatmap_width = 8
  profile_height = 6
  profile_width = 8

  // optional comma-separated labels in bigwig order
  samples_label = null

  container_deeptools = "/ictstr01/groups/idc/projects/uhlenhaut/jiang/singularity_image/deeptools-3.5.6.sif"
  queue = 'cpu_p'
  extra_mounts = ""

  cpus   = 8
  memory = '32 GB'
  time   = '8h'
}

profiles {
  local { includeConfig 'configs/local.config' }
  hpc   { includeConfig 'configs/slurm.config' }
}
